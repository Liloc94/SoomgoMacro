            "matchingMode": 0,
            "modificationDateTime": "2025-06-15T11:10:12.127",
            "name": "",
            "snippet": "평일, 주말 추가금 없이 예약 가능하신 시간은 09:00~18:00입니다 ^^",
            "uuid": "{5823da78-bc89-4639-9592-5762dcdf06b3}"
        },
        {
