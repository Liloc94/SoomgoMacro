            "matchingMode": 0,
            "modificationDateTime": "2025-07-04T10:42:42.853",
            "name": "",
            "snippet": "곰팡이도 추가금 없이 제거 가능하신데 곰팡이 자국 같은 경우는 에어컨 부품에 박혀버린거라 이런 부분까지 100% 제거는 다소 어려우실 수 있습니다 특히나 무풍 제품의 경우 마이크로홀은 기스가 나기 쉬운 부품이라 기스가 나지 않는 선에서 최대한 제거해드리고 있습니다 ^^",
            "uuid": "{fe077f8d-aa85-4f66-8cc2-a5fc5a0213d8}"
        },
